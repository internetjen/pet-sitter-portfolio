---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">

  <!-- HERO / INTRO -->
  <section class="about-hero">
    <div class="container about-hero__inner">
      <div class="about-hero__text">
        <p class="eyebrow">About Me</p>
        <h1>Hi, I'm [Name]! 🐾</h1>
        <p>I'm a passionate pet sitter based in [City] who believes every pet deserves to feel safe, loved, and cared for — even when their humans are away.</p>
      </div>
      <div class="about-hero__photo">
        <div class="photo-placeholder">📷</div>
      </div>
    </div>
  </section>

  <!-- MY STORY -->
  <section class="story">
    <div class="container story__inner">
      <p class="eyebrow">My Story</p>
      <h2>A lifelong love for animals</h2>
      <p>I grew up surrounded by animals — dogs, cats, rabbits, you name it. From a young age I knew that caring for animals wasn't just something I enjoyed, it was something I was meant to do. Over the years I've had the privilege of caring for dozens of pets and building lasting relationships with their families.</p>
      <p>What started as helping neighbors with their dogs quickly grew into a full-fledged passion. I've spent countless hours learning about animal behavior, first aid, and how to make every pet feel at ease in my care.</p>
    </div>
  </section>

  <!-- WHY I STARTED -->
  <section class="why">
    <div class="container">
      <p class="eyebrow">Why I Started</p>
      <h2>Pet sitting with purpose</h2>
      <div class="why__grid">
        <div class="why-card">
          <span class="why-card__icon">💛</span>
          <h3>A gap I noticed</h3>
          <p>I saw how stressful it was for pet owners to find someone they truly trusted. I wanted to be that person — reliable, caring, and genuinely invested.</p>
        </div>
        <div class="why-card">
          <span class="why-card__icon">🐶</span>
          <h3>Pets are family</h3>
          <p>I treat every animal in my care like my own. That means individualized attention, lots of love, and constant communication with their owners.</p>
        </div>
        <div class="why-card">
          <span class="why-card__icon">🤝</span>
          <h3>Building trust</h3>
          <p>My goal is for you to leave for your trip feeling completely at ease, knowing your pet is in the best possible hands.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ff6b35;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: #1a1a1a;
  }

  /* ── Hero ── */
  .about-hero {
    background: #fff8f5;
    padding: 5rem 1.5rem;
  }

  .about-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-hero__text h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .about-hero__text p {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.7;
  }

  .photo-placeholder {
    background: #f0f0f0;
    border-radius: 20px;
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
  }

  /* ── Story ── */
  .story {
    padding: 5rem 1.5rem;
  }

  .story__inner p {
    font-size: 1rem;
    color: #555;
    line-height: 1.8;
    max-width: 720px;
    margin-bottom: 1rem;
  }

  /* ── Why ── */
  .why {
    background: #fff8f5;
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .why-card {
    background: #fff;
    border: 2px solid #f0f0f0;
    border-radius: 16px;
    padding: 2rem 1.5rem;
    text-align: left;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .why-card:hover {
    border-color: #ff6b35;
    transform: translateY(-4px);
  }

  .why-card__icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
  }

  .why-card p {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .about-hero__inner {
      grid-template-columns: 1fr;
    }

    .photo-placeholder {
      height: 260px;
    }
  }
</style>