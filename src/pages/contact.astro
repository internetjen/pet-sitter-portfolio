---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">

  <!-- HERO -->
  <section class="contact-hero">
    <div class="container">
      <p class="eyebrow">Get in Touch</p>
      <h1>Let's talk about your pet! 🐾</h1>
      <p class="contact-hero__sub">Fill out the form below and I'll get back to you within 24 hours.</p>
    </div>
  </section>

  <!-- FORM -->
  <section class="contact-section">
    <div class="container contact-section__inner">

      <div class="contact-form-wrap">
        <form class="contact-form" name="contact" method="POST" data-netlify="true">

          <input type="hidden" name="form-name" value="contact" />

          <!-- Name & Email -->
          <div class="form-row">
            <div class="form-group">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" placeholder="Jane Smith" required />
            </div>
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="jane@email.com" required />
            </div>
          </div>

          <!-- Phone -->
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" />
          </div>

          <!-- Pet Info -->
          <div class="form-row">
            <div class="form-group">
              <label for="pet-name">Pet's Name</label>
              <input type="text" id="pet-name" name="pet-name" placeholder="Buddy" />
            </div>
            <div class="form-group">
              <label for="pet-age">Pet's Age</label>
              <input type="text" id="pet-age" name="pet-age" placeholder="e.g. 2 years" />
            </div>
          </div>

          <!-- Pet Type -->
          <div class="form-group">
            <label for="pet-type">Type of Pet</label>
            <select id="pet-type" name="pet-type">
              <option value="" disabled selected>Select pet type</option>
              <option value="dog">Dog</option>
              <option value="cat">Cat</option>
              <option value="puppy">Puppy</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Service Needed -->
          <div class="form-group">
            <label for="service">Service Needed</label>
            <select id="service" name="service">
              <option value="" disabled selected>Select a service</option>
              <option value="dog-walking">Dog Walking</option>
              <option value="pet-sitting">Pet Sitting / Drop-in Visits</option>
              <option value="overnight">Overnight Stays</option>
              <option value="cat-checkin">Cat Check-ins</option>
              <option value="puppy-care">Puppy Care</option>
            </select>
          </div>

          <!-- Preferred Dates -->
          <div class="form-row">
            <div class="form-group">
              <label for="date-start">Start Date</label>
              <input type="date" id="date-start" name="date-start" />
            </div>
            <div class="form-group">
              <label for="date-end">End Date</label>
              <input type="date" id="date-end" name="date-end" />
            </div>
          </div>

          <!-- Message -->
          <div class="form-group">
            <label for="message">Anything else I should know?</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell me about your pet, their routine, any special needs..."></textarea>
          </div>

          <button type="submit" class="btn-submit">Send Message 🐾</button>

        </form>
      </div>

      <!-- SIDEBAR -->
      <aside class="contact-sidebar">
        <div class="sidebar-card">
          <span class="sidebar-card__icon">📍</span>
          <h3>Location</h3>
          <p>Chicago, IL</p>
        </div>
        <div class="sidebar-card">
          <span class="sidebar-card__icon">📧</span>
          <h3>Email</h3>
          <p>hello@pawsome.com</p>
        </div>
        <div class="sidebar-card">
          <span class="sidebar-card__icon">📱</span>
          <h3>Phone</h3>
          <p>(555) 000-0000</p>
        </div>
        <div class="sidebar-card">
          <span class="sidebar-card__icon">🕐</span>
          <h3>Response Time</h3>
          <p>Within 24 hours</p>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #7c7dbe;
    margin-bottom: 0.5rem;
  }

  /* ── Hero ── */
  .contact-hero {
    background: #eeeef8;
    padding: 5rem 1.5rem;
  }

  .contact-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .contact-hero__sub {
    font-size: 1.05rem;
    color: #555;
    max-width: 520px;
    line-height: 1.7;
  }

  /* ── Contact Section ── */
  .contact-section {
    padding: 5rem 1.5rem;
  }

  .contact-section__inner {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: start;
  }

  /* ── Form ── */
  .contact-form-wrap {
    background: #fff;
    border: 2px solid #ddddf0;
    border-radius: 20px;
    padding: 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  label {
    font-size: 0.88rem;
    font-weight: 600;
    color: #1a1a1a;
  }

  input,
  select,
  textarea {
    padding: 0.7rem 1rem;
    border: 2px solid #ddddf0;
    border-radius: 10px;
    font-size: 0.95rem;
    font-family: inherit;
    color: #1a1a1a;
    background: #f8f8fd;
    transition: border-color 0.2s ease;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  input[type="date"] {
    appearance: none;
    -webkit-appearance: none;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: #7c7dbe;
    background: #fff;
  }

  input::placeholder,
  textarea::placeholder {
    color: #bbb;
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    background: #7c7dbe;
    color: #fff;
    border: none;
    padding: 0.85rem 2rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    align-self: flex-start;
  }

  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(124,125,190,0.35);
  }

  /* ── Sidebar ── */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-card {
    background: #fff;
    border: 2px solid #ddddf0;
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    transition: border-color 0.2s ease;
  }

  .sidebar-card:hover {
    border-color: #7c7dbe;
  }

  .sidebar-card__icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.4rem;
  }

  .sidebar-card h3 {
    font-size: 0.85rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 0.2rem;
  }

  .sidebar-card p {
    font-size: 0.9rem;
    color: #666;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .contact-hero {
      padding: 3rem 1.25rem;
    }

    .contact-section {
      padding: 3rem 1.25rem;
    }

    .contact-section__inner {
      grid-template-columns: 1fr;
    }

    .contact-form-wrap {
      padding: 1.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .btn-submit {
      align-self: stretch;
      text-align: center;
    }

    .contact-sidebar {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .sidebar-card {
      flex: 1 1 calc(50% - 0.5rem);
    }
  }

  @media (max-width: 400px) {
    .contact-sidebar {
      flex-direction: column;
    }

    .sidebar-card {
      flex: 1 1 100%;
    }
  }
</style>