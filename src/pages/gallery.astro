---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import pet1 from '../assets/images/pet-1.jpg';
// import pet2 from '../assets/images/pet-2.jpg';
// import pet3 from '../assets/images/pet-3.jpg';
// import pet4 from '../assets/images/pet-4.jpg';
// import pet5 from '../assets/images/pet-5.jpg';
// import pet6 from '../assets/images/pet-6.jpg';
// import pet7 from '../assets/images/pet-7.jpg';
// import pet8 from '../assets/images/pet-8.jpg';
// import pet9 from '../assets/images/pet-9.jpg';

const photos = [
  { src: pet1, alt: "A happy dog on a walk" },
  { src: pet1, alt: "A happy dog on a walk" },
  { src: pet1, alt: "A happy dog on a walk" },
  { src: pet1, alt: "A happy dog on a walk" },
  { src: pet1, alt: "A happy dog on a walk" },
  { src: pet1, alt: "A happy dog on a walk" },
  { src: pet1, alt: "A happy dog on a walk" },
  { src: pet1, alt: "A happy dog on a walk" },
  { src: pet1, alt: "A happy dog on a walk" },
];
---

<BaseLayout title="Gallery">

  <!-- HERO -->
  <section class="gallery-hero">
    <div class="container">
      <p class="eyebrow">Gallery</p>
      <h1>Faces I've had the pleasure of caring for 🐾</h1>
      <p class="gallery-hero__sub">Every pet has a personality all their own. Here are some of my favorite furry friends.</p>
    </div>
  </section>

  <!-- MASONRY GRID -->
  <section class="gallery-section">
    <div class="container">
      <div class="masonry">
        {photos.map((photo) => (
          <div class="masonry__item">
            <Image src={photo.src} alt={photo.alt} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container cta__inner">
      <h2>Want your pet to be featured? 📸</h2>
      <p>Book a visit and your furry friend could be next!</p>
      <a href="/contact" class="btn btn--white">Get in Touch</a>
    </div>
  </section>

</BaseLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #7c7dbe;
    margin-bottom: 0.5rem;
  }

  .btn {
    display: inline-block;
    padding: 0.65rem 1.4rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    background: #7c7dbe;
    color: #fff;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  }

  .btn--white {
    background: #fff;
    color: #7c7dbe;
  }

  /* ── Hero ── */
  .gallery-hero {
    background: #eeeef8;
    padding: 5rem 1.5rem;
  }

  .gallery-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .gallery-hero__sub {
    font-size: 1.05rem;
    color: #555;
    max-width: 560px;
    line-height: 1.7;
  }

  /* ── Masonry ── */
  .gallery-section {
    padding: 5rem 1.5rem;
  }

  .masonry {
    columns: 3;
    column-gap: 1rem;
  }

  .masonry__item {
    break-inside: avoid;
    margin-bottom: 1rem;
    border-radius: 16px;
    overflow: hidden;
    background: #cccde8;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .masonry__item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.12);
  }

  .masonry__item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  .masonry__item:hover img {
    transform: scale(1.03);
  }

  /* ── CTA ── */
  .cta {
    background: #7c7dbe;
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .cta__inner h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .cta__inner p {
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .gallery-hero {
      padding: 3rem 1.25rem;
    }

    .gallery-section {
      padding: 3rem 1.25rem;
    }

    .cta {
      padding: 3rem 1.25rem;
    }

    .masonry {
      columns: 2;
    }
  }

  @media (max-width: 480px) {
    .masonry {
      columns: 1;
    }
  }
</style>