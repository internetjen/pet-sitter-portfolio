---
const navLinks = [
  { href: "/",         label: "Home" },
  { href: "/about",    label: "About" },
  { href: "/services", label: "Services" },
  { href: "/gallery",  label: "Gallery" },
  { href: "/contact",  label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo">🐾 Pawsome</a>

    <!-- Desktop nav -->
    <nav class="navbar__links" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={"nav-link" + (currentPath === href ? " nav-link--active" : "")}
        >
          {label}
        </a>
      ))}
    </nav>

    <a href="/contact" class="navbar__cta">Book Now</a>

    <!-- Hamburger button (mobile only) -->
    <button class="navbar__hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar__mobile" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={"mobile-link" + (currentPath === href ? " mobile-link--active" : "")}
        >
          {label}
        </a>
      ))}
      <a href="/contact" class="mobile-cta">Book Now</a>
    </nav>
  </div>
</header>

<style>
  .navbar {
    background: #fff;
    border-bottom: 2px solid #cccde8;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .navbar__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .navbar__logo {
    font-size: 1.4rem;
    font-weight: 700;
    color: #7c7dbe;
    text-decoration: none;
    margin-right: auto;
    letter-spacing: -0.02em;
  }

  /* ── Desktop nav ── */
  .navbar__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 500;
    color: #333;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .nav-link:hover {
    background: #eeeef8;
    color: #7c7dbe;
  }

  .nav-link--active {
    background: #eeeef8;
    color: #7c7dbe;
    font-weight: 600;
  }

  .navbar__cta {
    background: #7c7dbe;
    color: #fff;
    padding: 0.5rem 1.2rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .navbar__cta:hover {
    background: #5a5ba0;
    transform: translateY(-1px);
  }

  /* ── Hamburger button ── */
  .navbar__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    margin-left: auto;
  }

  .navbar__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #333;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Animate hamburger to X when open */
  .navbar__hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .navbar__hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .navbar__hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile menu ── */
  .navbar__mobile {
    display: none;
    flex-direction: column;
    background: #fff;
    border-top: 1px solid #cccde8;
    padding: 1rem 1.5rem 1.5rem;
    gap: 0.25rem;
  }

  .navbar__mobile nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .navbar__mobile.is-open {
    display: flex;
  }

  .mobile-link {
    display: block;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 500;
    color: #333;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .mobile-link:hover {
    background: #eeeef8;
    color: #7c7dbe;
  }

  .mobile-link--active {
    background: #eeeef8;
    color: #7c7dbe;
    font-weight: 600;
  }

  .mobile-cta {
    display: block;
    margin-top: 0.75rem;
    padding: 0.85rem 1rem;
    background: #7c7dbe;
    color: #fff;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .mobile-cta:hover {
    background: #5a5ba0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .navbar__links,
    .navbar__cta {
      display: none;
    }

    .navbar__hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.querySelector('.navbar__hamburger');
  const mobileMenu = document.querySelector('.navbar__mobile');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close menu when a link is clicked
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('is-open');
      hamburger?.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });
</script>