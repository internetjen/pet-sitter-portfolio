---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__logo">🐾 Pawsome</p>
    <p class="footer__copy">&copy; {year} Pawsome Petsitting. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: #ff6b35;
    color: #fff;
    padding: 2rem 1.5rem;
    margin-top: auto;
  }

  .footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .footer__logo {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .footer__copy {
    font-size: 0.85rem;
    opacity: 0.85;
  }
</style>